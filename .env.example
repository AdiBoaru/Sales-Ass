# =============================================================================
# Nativx Assistant — exemplu de configurare
# Copiază în `.env` și completează cu valori reale (NU comite .env).
# =============================================================================

# --- Supabase / Postgres -----------------------------------------------------
# Botul se conectează prin asyncpg DIRECT la Postgres, NU prin clientul HTTP.
# Două roluri (NX-50, vezi docs/db_connections.md):
#
# 1) admin_pool — CONTROL PLANE (resolve_channel) + joburi + migrări. Privilegiat.
#    Connection string direct (port 5432) sau pooler (port 6543).
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
#
# 2) bot_pool — TENANT PATH. Rol de LOGIN `bot_runtime` (fără bypassrls), parolă
#    proprie, conexiune DIRECTĂ (port 5432, NU pooler transaction-mode).
#    Provisioning o dată: BOT_RUNTIME_PASSWORD='...' python scripts/apply_005.py
#    Gol → cade grațios pe SUPABASE_DB_URL + SET ROLE (DOAR dev/test, nu prod).
DATABASE_URL_BOT=postgresql://bot_runtime:[BOT_PASSWORD]@db.xxxx.supabase.co:5432/postgres
#
# NX-04: assert rol+app.business_id la fiecare checkout din bot_pool (fail-fast).
# 'strict' (default) = IsolationError înainte de primul query; 'off' = sare (WARNING la boot).
DB_ISOLATION_ASSERT=strict

# --- Supabase JS client (DOAR pentru scripturile de seed/embed din db/seed) ---
# Folosite de `npm run seed` și `npm run embed` (tsx), nu de botul Python.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SEED_BUSINESS_SLUG=sole-demo
SEED_BUSINESS_NAME=Sole Demo

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
MODEL_AGENT=gpt-5.4-mini
MODEL_TRIAGE=gpt-5.4-nano
MODEL_EMBED=text-embedding-3-small
MODEL_MODERATION=omni-moderation-latest
# Override tarife pt observabilitatea de cost (NX-103). JSON parțial, merge peste implicitul din
# src/agent/pricing.py — tunabil în prod fără redeploy. Gol → tarifele documentate din cod.
# LLM_PRICING_JSON={"gpt-5.4-mini":{"input":0.25,"cached_input":0.025,"output":2.00}}
LLM_PRICING_JSON=

# --- Moderation gate (NX-15) -------------------------------------------------
MODERATION_ENABLED=true           # poartă în gates: mesaj flagged → răspuns neutru (gratuit)
MODERATION_BLOCK_THRESHOLD=3      # flag-uri în 24h → abuse blocklist (contacts.is_blocked)

# --- Media routing: Vision poză→catalog (NX-76, stagiul 3) -------------------
VISION_ENABLED=true               # poză (content_type=image) → descriere Vision ca text de căutare
MODEL_VISION=gpt-5.4-mini         # modelul cu vedere (nano n-are); default = model agent
VISION_MAX_BYTES=5000000          # cap mărime poză descărcată; peste = fail-soft (clarificare)
COST_VISION_USD=0.003             # estimare cost/apel Vision pt contorul zilnic G2c

# --- Meta WhatsApp Cloud API -------------------------------------------------
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PHONE_NUMBER_ID=

# --- Redis -------------------------------------------------------------------
# Parolă OBLIGATORIE (NX-02): Redis e backbone-ul cu mesaje de client în zbor.
# Generează 32+ chars: `openssl rand -base64 32`. URL-ul include parola.
REDIS_PASSWORD=schimba-ma-parola-redis-32-chars-minim
REDIS_URL=redis://:schimba-ma-parola-redis-32-chars-minim@redis:6379/0

# --- Telegram (canal de TEST — long polling, fără webhook/HTTPS) -------------
# Token de la BotFather (/newbot). Gol = pollerul Telegram nu pornește.
TELEGRAM_BOT_TOKEN=

# --- Web Widget (NX-20, E26 — al treilea canal, V1.5) ------------------------
WEB_ENABLED=false                # gateway web (POST /web/messages SSE + POST /web/chat sincron); OFF până la V1.5
WEB_SESSION_SECRET_TTL_S=60      # TTL cache public_token→(business_id, session_secret)
WEB_RATE_LIMIT_MAX_VISITOR=15    # max mesaje/fereastră per visitor_id (web public anonim)
WEB_RATE_LIMIT_MAX_IP=40         # max mesaje/fereastră per (token, IP) — prinde rotirea de visitor
WEB_RATE_LIMIT_WINDOW_S=60       # fereastra rate limit web (secunde)
WEB_SSE_HEARTBEAT_S=15           # heartbeat „: keepalive" pe SSE (ține proxy-ul deschis)
WEB_BACKLOG_SIZE=20              # mesaje păstrate per vizitator pt reconectare (Last-Event-ID)
WEB_BACKLOG_TTL_S=300            # TTL backlog SSE (secunde)
WEB_CORS_ORIGINS=                # CSV origin-uri permise pt POST /web/chat (ex. https://shop.ro,http://localhost:5173); gol → doar same-origin
# NX-120 (DoS hardening): cap de body pe ingestie + cost-cap zilnic per vizitator web.
WEB_MAX_BODY_BYTES=16384         # cap body /web/* (text capat la 2000 char → 16KB acoperă JSON-ul)
WEBHOOK_MAX_BODY_BYTES=262144    # cap body webhook Meta/orders (payload-uri mici → 256KB generos)
WEB_COST_CAP_PER_VISITOR_USD=0.50 # plafon zilnic de cost LLM per vizitator web (token furat ≠ buget golit)

# --- App ---------------------------------------------------------------------
ENV=dev                          # dev | staging | prod
LOG_LEVEL=INFO
DAILY_COST_CAP_USD=5             # cost guard zilnic per business
OPERATOR_ALERT_WEBHOOK=          # optional — URL notificare operator la handoff
HANDOFF_WINDOW_MINUTES=45        # G5a: cât tace botul după handoff (risc/preluare)

# --- Mesaj de întâmpinare (free layer, stagiul 4) ----------------------------
WELCOME_ENABLED=true             # pur salut → mesaj de welcome branded, determinist (fără LLM)
WELCOME_BOT_NAME=Native          # numele asistentului; override per business în settings["welcome"]

# --- Strat gratuit alias (NX-73, stagiul 4) ----------------------------------
ALIAS_ENABLED=true               # match exact `intent_aliases` aprobate, înainte de cache; zero LLM

# --- Cache semantic (G5b) ----------------------------------------------------
CACHE_ENABLED=true               # stratul gratuit 4: servește răspunsuri repetate fără LLM
CACHE_TAU_HIGH=0.92              # prag auto-accept L2 semantic (cosine); conservator
CACHE_TTL_STATIC_DAYS=7         # TTL entry-uri static (FAQ/generic)
CACHE_TTL_DYNAMIC_MINUTES=30    # TTL backstop dynamic (produs); invalidarea reală = price-check

# --- Strat gratuit FAQ (NX-74, stagiul 4) ------------------------------------
FAQ_ENABLED=true                 # întrebări de cunoștințe → răspuns din `faqs` fără LLM de generare
FAQ_TAU_HIGH=0.82                # prag auto-accept strat gratuit (cosine); precision-first
FAQ_TAU_TOOL=0.75               # prag tool faq_lookup (agentul parafrazează → mai relaxat)

VALIDATOR_CLAIMS_ENABLED=true    # NX-117: calea de proză respinge claim-uri ne-numerice (superlativ); fail-open
VALIDATOR_STOCK_CLAIMS_ENABLED=false  # NX-118: „pe stoc" availability-aware; OFF (depinde de calitatea datelor)

# --- Guardrails de input la gate (NX-121, stagiul 3) ------------------------
INPUT_PII_MASK_ENABLED=true       # maschează telefon/email/IBAN/card din corpul inbound (P12)
INJECTION_SCREEN_ENABLED=false    # ecran anti-injection (detectare); OFF până e seedat DomainPack

# --- Adaptor OpenAI: reziliență (NX-126) ------------------------------------
LLM_TIMEOUT_S=30.0               # timeout per apel OpenAI (anti-hang, mai ales pe web sincron)
LLM_RETRY_MAX=2                  # retry bounded pe tranzitoriu (429/5xx/timeout); respectă Retry-After
LLM_SAMPLING_ENABLED=true        # ON = trimite `temperature`; OFF = o omite (kill-switch per-model)
LLM_TEMPERATURE_TRIAGE=0.2       # temperatura triajului (clasificare deterministă; doar dacă SAMPLING_ENABLED)
LLM_TEMPERATURE_AGENT=0.7        # temperatura agentului (copy variat, ne-repetitiv; doar dacă SAMPLING_ENABLED)
LLM_MAX_TOKENS_AGENT=800         # plafon output agent → max_completion_tokens (NU max_tokens; nu embed/moderate)
AI_DISCLAIMER_ENABLED=false      # dezvăluire AI (art. 50 AI Act): OFF default (nu pe fiecare mesaj); ON o repune

# --- Cost guard + rate limit (G2c, stagiul 2) --------------------------------
COST_GUARD_ENABLED=true          # peste plafonul zilnic → LLM dezactivat (degradare grațioasă)
COST_TRIAGE_USD=0.0003           # estimare cost/tur triaj (nano); plasă, nu facturare
COST_AGENT_USD=0.003             # estimare cost/apel agent (mini); tool-calling ×(1+nr tools)
CONTACT_DAILY_COST_CAP_USD=0     # NX-125: plafon SOFT per-contact (canale identificate); 0=off (opt-in)
RATE_LIMIT_ENABLED=true          # rate limit per contact (peste debounce R1)
RATE_LIMIT_MAX=20                # max mesaje per fereastră
RATE_LIMIT_WINDOW_SECONDS=60     # fereastra rate limit (secunde)

# --- Comerț / bucla de bani (F2) --------------------------------------------
CHECKOUT_BASE_URL=               # base URL checkout (gol → checkout_link ok=False; ?ref= adăugat în cod)
CHECKOUT_LINK_TTL_DAYS=7         # valabilitatea unui link de checkout (zile)
ORDERS_WEBHOOK_SECRET=           # secret HMAC pt X-Orders-Signature: sha256=<hmac(corp brut)> pe /webhook/orders (gol → 403)

# --- Summarizer conversații lungi (G6-2 felia 2, stagiul 6) -----------------
SUMMARY_ENABLED=true             # kill-switch: generare post-tur + citire în context
SUMMARY_THRESHOLD=20             # nr. mesaje/conversație de la care se sumarizează (>= prag)
SUMMARY_REGEN_DELTA=12           # re-sumarizează doar la >= atâtea mesaje noi peste watermark
SUMMARY_MAX_CHARS=600            # bugetul blocului de rezumat în prompt

# --- Mini-scheduler joburi de mentenanță (NX-83) ----------------------------
EMBED_JOB_ENABLED=true              # embed_products orar incremental (doar dacă OPENAI_API_KEY e setat)
SCHEDULER_ROLLUP_HOUR_UTC=0         # ora UTC la care rulează rollup_usage (facturare/dashboard)
SCHEDULER_DEDUPE_INTERVAL_SECONDS=21600   # purjă inbound_dedupe >48h (la 6h)
SCHEDULER_EMBED_INTERVAL_SECONDS=3600     # embed incremental (orar; content_hash → $0 dacă nimic nou)

# --- Extractor profil + lead_score (NX-88, post-tur stagiul 9) ---------------
PROFILE_EXTRACTION_ENABLED=true  # nano post-tur: profil whitelist + lead_score determinist (guardat de cost guard)

# --- Motor proactiv (NX-70, scheduler separat) ------------------------------
PROACTIVE_ENABLED=true           # AWB / back-in-stock / coș abandonat / follow-up → outbox
PROACTIVE_BATCH_SIZE=20          # joburi revendicate per ciclu, per tenant
PROACTIVE_IDLE_SLEEP_S=5         # somn între cicluri când nu e nimic scadent

# --- Validator cifre bare (NX-91, stagiul 8) --------------------------------
VALIDATOR_BARE_NUMBERS_ENABLED=true  # prinde cifre fără valută negroundate (stoc/rating inventat); fail-open
# --- Typing indicator + spargere reply (NX-90, stagiul 9) -------------------
TYPING_ENABLED=true              # „typing…" instant pe inbound (best-effort, direct prin canal)
REPLY_SPLIT_CHARS=200            # reply peste atâtea caractere → spart în max 2 mesaje

# --- Lock per conversație (NX-85, stagiul 2 — ordonare multi-consumer) -------
CONV_LOCK_ENABLED=true           # serializează tururile aceleiași conversații între replici
CONV_LOCK_TTL_SECONDS=30         # TTL lock (plasă dacă worker-ul moare cu lock-ul luat)
CONV_LOCK_REQUEUE_DELAY_MS=150   # backoff la re-queue când conversația e ocupată
CONV_LOCK_MAX_REQUEUES=10        # cap dur de reîncercări → drop (nu rebuclează la infinit)
