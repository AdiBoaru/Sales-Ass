# =============================================================================
# Nativx Assistant — exemplu de configurare
# Copiază în `.env` și completează cu valori reale (NU comite .env).
# =============================================================================

# --- Supabase / Postgres (runtime bot) ---------------------------------------
# Botul se conectează prin asyncpg DIRECT la Postgres, NU prin clientul HTTP.
# Connection string direct (port 5432) sau pooler (port 6543).
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# --- Supabase JS client (DOAR pentru scripturile de seed/embed din db/seed) ---
# Folosite de `npm run seed` și `npm run embed` (tsx), nu de botul Python.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SEED_BUSINESS_SLUG=sole-demo
SEED_BUSINESS_NAME=Sole Demo

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
MODEL_AGENT=gpt-5.4-mini
MODEL_TRIAGE=gpt-5.4-nano
MODEL_EMBED=text-embedding-3-small

# --- Meta WhatsApp Cloud API -------------------------------------------------
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PHONE_NUMBER_ID=

# --- Redis -------------------------------------------------------------------
# Parolă OBLIGATORIE (NX-02): Redis e backbone-ul cu mesaje de client în zbor.
# Generează 32+ chars: `openssl rand -base64 32`. URL-ul include parola.
REDIS_PASSWORD=schimba-ma-parola-redis-32-chars-minim
REDIS_URL=redis://:schimba-ma-parola-redis-32-chars-minim@redis:6379/0

# --- App ---------------------------------------------------------------------
ENV=dev                          # dev | staging | prod
LOG_LEVEL=INFO
DAILY_COST_CAP_USD=5             # cost guard zilnic per business
OPERATOR_ALERT_WEBHOOK=          # optional — URL notificare operator la handoff
