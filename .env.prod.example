# =============================================================================
# Nativx Assistant — PRODUCȚIE (VPS Hostinger + Traefik existent)
# Copiază în `.env` PE VPS și completează. NU comite .env-ul real.
# Acest fișier e citit ȘI de aplicație (env_file) ȘI de docker compose (${VAR}).
# =============================================================================

# --- Docker Compose (selectează prod + numele proiectului, fără flag-uri) -----
# Cu astea, un `docker compose up -d` SIMPLU din /opt/nativextech/nativx/ folosește
# automat compose-ul de PROD și proiectul „nativx" — la fel ca celelalte stack-uri
# din /opt/nativextech/. Previne și pornirea accidentală a docker-compose.yml (DEV).
COMPOSE_FILE=docker-compose.prod.yml
COMPOSE_PROJECT_NAME=nativx

# --- App ---------------------------------------------------------------------
ENV=prod
LOG_LEVEL=INFO
DAILY_COST_CAP_USD=5             # cost guard zilnic per business

# --- Routing Traefik (citit DOAR de docker-compose.prod.yml, nu de app) ------
# Subdomeniul pe care Traefik rutează webhook-ul. A-record către 72.62.34.245.
# entrypoint (websecure) + certresolver (letsencrypt) sunt HARDCODATE în compose
# (confirmate din Traefik) → aici trebuie DOAR host-ul. ACELAȘI host servește și
# widgetul web (/web/chat) → frontendul folosește VITE_CHAT_API_BASE=https://WEBHOOK_HOST.
WEBHOOK_HOST=bot.nativextech.com

# --- Supabase / Postgres -----------------------------------------------------
# ⚠️ Parola TREBUIE percent-encoded în URL (asyncpg crapă în container la caractere
#    speciale: @ → %40, # → %23, etc.). Vezi memoria „db-url-password-encoding".
# 1) admin_pool (control plane + joburi + migrări) — privilegiat.
SUPABASE_DB_URL=postgresql://postgres:[PAROLA_ENCODED]@db.xxxx.supabase.co:5432/postgres
# 2) bot_pool (tenant path) — rol de LOGIN `bot_runtime`, fără bypassrls.
#    Provisioning o dată: BOT_RUNTIME_PASSWORD='...' python scripts/apply_005.py
DATABASE_URL_BOT=postgresql://bot_runtime:[BOT_PAROLA_ENCODED]@db.xxxx.supabase.co:5432/postgres
DB_ISOLATION_ASSERT=strict       # prod: fail-fast la izolare greșită

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
MODEL_AGENT=gpt-5.4-mini
MODEL_TRIAGE=gpt-5.4-nano
MODEL_EMBED=text-embedding-3-small
MODEL_MODERATION=omni-moderation-latest

# --- Adaptor OpenAI: sampling (NX-126) ---------------------------------------
# Opționale — default-uri sănătoase în config.py. Modelele gpt-5.4-* folosesc
# `max_completion_tokens` (NU `max_tokens`) și ACCEPTĂ `temperature`.
# LLM_SAMPLING_ENABLED=true        # ON = trimite temperature; OFF = o omite (kill-switch per-model)
# LLM_TEMPERATURE_TRIAGE=0.2       # clasificare deterministă
# LLM_TEMPERATURE_AGENT=0.7        # copy variat, ne-repetitiv (corectitudinea = validatorul stagiul 8)

# --- Redis (DEDICAT nativx) --------------------------------------------------
# Parolă proprie, separată de orice alt redis de pe VPS. `openssl rand -base64 32`.
# Hostname `redis` = numele serviciului din compose (rețeaua internă nativx).
REDIS_PASSWORD=schimba-ma-32-chars-minim
REDIS_URL=redis://:schimba-ma-32-chars-minim@redis:6379/0

# --- Meta WhatsApp Cloud API (Faza 3 — număr SEPARAT, nu Evolution) ----------
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=               # string ales de tine; îl pui și în Meta dashboard
META_PHONE_NUMBER_ID=            # T013

# --- Telegram (canal de TEST — long polling) ---------------------------------
# Gol = telegram-poller iese imediat (nu blochează restul).
TELEGRAM_BOT_TOKEN=

# --- Web widget (canal webchat — chat pe site) -------------------------------
# Endpointurile /web/* trăiesc în serviciul `webhook` (deja rutat de Traefik pe WEBHOOK_HOST).
# `/web/chat` (sincron) rulează pipeline-ul IN-PROCES în `webhook` → are nevoie de OPENAI_API_KEY
# + DATABASE_URL_BOT (deja în acest .env). Seed-ul canalului: `python scripts/seed_web_channel.py`
# (afișează public_token-ul de pus în frontend).
WEB_ENABLED=true
# CORS: originea EXACTĂ a site-ului care încarcă widgetul — scheme+host, FĂRĂ slash final și FĂRĂ
# path (browserul trimite `https://shop.nativextech.com`, nu `.../`). CSV pt mai multe origini.
WEB_CORS_ORIGINS=https://shop.nativextech.com
# NX-120 (DoS hardening): cap body ingestie + cost-cap zilnic per vizitator web. Pe VPS mic
# (0-swap) un POST mare poate OOM-ui procesul → respins cu 413 înainte de a-l citi. Defense-in-depth
# la Traefik (buffering.maxRequestBodyBytes) — vezi DEPLOY.md; gardul de app rămâne sursa de adevăr.
WEB_MAX_BODY_BYTES=16384
WEBHOOK_MAX_BODY_BYTES=262144
WEB_COST_CAP_PER_VISITOR_USD=0.50

# --- Moderation / welcome / straturi gratuite --------------------------------
MODERATION_ENABLED=true
MODERATION_BLOCK_THRESHOLD=3
WELCOME_ENABLED=true
WELCOME_BOT_NAME=Native
ALIAS_ENABLED=true
CACHE_ENABLED=true
CACHE_TAU_HIGH=0.92
CACHE_TTL_STATIC_DAYS=7
CACHE_TTL_DYNAMIC_MINUTES=30
FAQ_ENABLED=true
FAQ_TAU_HIGH=0.82
FAQ_TAU_TOOL=0.75

# --- Cost guard + rate limit -------------------------------------------------
COST_GUARD_ENABLED=true
COST_TRIAGE_USD=0.0003
COST_AGENT_USD=0.003
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60

# --- Retrieval & ranking de produse (ARCH-2026 P0) --------------------------
# Pe `relevance`: scor blended (RRF + social-proof rating + stoc/reducere/concern) + carduri
# ordonate de ranking, „Recomandarea mea" = top-ul clasat (modelul doar narează). Default ON
# (în cod). Kill-switch FAIL-SAFE pt revert fără redeploy → RRF pur / ordine de model.
# SEARCH_BLENDED_RANK_ENABLED=true
# RICH_PICK_DETERMINISTIC_ENABLED=true

# --- Comerț ------------------------------------------------------------------
CHECKOUT_BASE_URL=
CHECKOUT_LINK_TTL_DAYS=7
ORDERS_WEBHOOK_SECRET=

# --- Summarizer + scheduler + proactiv ---------------------------------------
SUMMARY_ENABLED=true
SUMMARY_THRESHOLD=20
SUMMARY_REGEN_DELTA=12
SUMMARY_MAX_CHARS=600
EMBED_JOB_ENABLED=true
SCHEDULER_ROLLUP_HOUR_UTC=0
SCHEDULER_DEDUPE_INTERVAL_SECONDS=21600
SCHEDULER_EMBED_INTERVAL_SECONDS=3600
PROACTIVE_ENABLED=true
PROACTIVE_BATCH_SIZE=20
PROACTIVE_IDLE_SLEEP_S=5
PROACTIVE_INITIATORS_ENABLED=true
PROACTIVE_INITIATORS_INTERVAL_S=900
PROACTIVE_INITIATORS_BATCH=200
ABANDONED_CART_AFTER_SECONDS=3600
ABANDONED_CART_MAX_AGE_SECONDS=604800

# --- Operator alert ----------------------------------------------------------
OPERATOR_ALERT_WEBHOOK=
HANDOFF_WINDOW_MINUTES=45
# Handoff la om DOAR pe canalele listate. Web (webchat) e exclus deliberat: nu există operator pe
# web (consolă/inbox = task viitor) → botul răspunde singur. Adaugă `,webchat` când web-ul are operator.
HANDOFF_ENABLED_CHANNELS=whatsapp,telegram
